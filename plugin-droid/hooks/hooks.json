{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Create|ApplyPatch|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node \"${DROID_PLUGIN_ROOT}/scripts/touch-sync-trigger.js\""
                    }
                ]
            }
        ]
    }
}
