# Copy this file to .env and replace every value before starting the stack.
GEMDEX_SERVER_TOKEN=replace-with-a-long-random-bearer-token
GEMINI_API_KEY=replace-with-your-google-ai-key
POSTGRES_PASSWORD=replace-with-a-long-random-database-password

# Host port published on 127.0.0.1. Put a TLS reverse proxy in front when
# exposing Gemdex beyond this machine.
GEMDEX_SERVER_PORT=8765

# Optional comma-separated browser origins. CLI/MCP clients do not send Origin.
GEMDEX_SERVER_ALLOWED_ORIGINS=
