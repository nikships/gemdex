{
    "name": "gemdex-server",
    "version": "1.0.8",
    "description": "Self-hostable Gemdex Server — the official BYOI remote backend HTTP service",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "gemdex-server": "dist/index.js"
    },
    "scripts": {
        "init": "bash scripts/init.sh",
        "build": "pnpm clean && tsc --build --force",
        "clean": "rimraf dist",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "typecheck": "tsc --noEmit",
        "test": "node --import tsx --test src/*.test.ts",
        "start": "tsx src/index.ts",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "gemdex-core": "workspace:*",
        "pg": "^8.21.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/pg": "^8.20.0",
        "pg-mem": "^3.0.14",
        "tsx": "^4.19.4",
        "typescript": "^5.0.0"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/anand-92/gemdex.git",
        "directory": "packages/server"
    },
    "license": "MIT",
    "author": "Nikhil Anand",
    "publishConfig": {
        "access": "public"
    }
}
